{
  "mcpServers": {

    "_comment_core": "=== CORE — Necesarios para el flujo básico de Forge ===",

    "_comment_baas": "=== BaaS — Elige Supabase O InsForge, no ambos ===",

    "supabase": {
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--project-ref=YOUR_SUPABASE_PROJECT_REF"
      ],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "YOUR_SUPABASE_ACCESS_TOKEN"
      }
    },

    "_comment_insforge_alt": "InsForge: alternativa agents-first a Supabase (OAuth, sin tokens locales)",
    "_insforge_disabled": {
      "type": "http",
      "url": "https://mcp.insforge.dev/mcp"
    },

    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "next-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "next-devtools-mcp@latest"
      ]
    },
    "shadcn": {
      "command": "npx",
      "args": [
        "shadcn@latest",
        "mcp"
      ]
    },

    "_comment_optional_dev": "=== OPCIONALES: Desarrollo y debugging ===",

    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },

    "_comment_optional_creative": "=== OPCIONALES: Assets creativos ===",

    "svgmaker": {
      "command": "npx",
      "args": [
        "@genwave/svgmaker-mcp"
      ],
      "transport": "stdio",
      "env": {
        "SVGMAKER_API_KEY": "YOUR_SVGMAKER_API_KEY"
      }
    },

    "_comment_optional_infra": "=== OPCIONALES: Infraestructura y servicios ===",

    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_PAT"
      }
    },
    "stripe": {
      "command": "npx",
      "args": [
        "-y",
        "@stripe/mcp",
        "--tools=all"
      ],
      "env": {
        "STRIPE_SECRET_KEY": "YOUR_STRIPE_SECRET_KEY"
      }
    },
    "sentry": {
      "command": "npx",
      "args": [
        "-y",
        "@sentry/mcp-server@latest"
      ],
      "env": {
        "SENTRY_AUTH_TOKEN": "YOUR_SENTRY_AUTH_TOKEN"
      }
    },
    "resend": {
      "command": "npx",
      "args": [
        "-y",
        "resend-mcp@latest"
      ],
      "env": {
        "RESEND_API_KEY": "YOUR_RESEND_API_KEY"
      }
    },

    "_comment_optional_research": "=== OPCIONALES: Research y contenido ===",

    "perplexity": {
      "command": "npx",
      "args": [
        "-y",
        "@perplexity-ai/mcp-server"
      ],
      "env": {
        "PERPLEXITY_API_KEY": "YOUR_PERPLEXITY_API_KEY"
      }
    },
    "brave-search": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "env": {
        "BRAVE_API_KEY": "YOUR_BRAVE_API_KEY"
      }
    },
    "firecrawl-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "firecrawl-mcp"
      ],
      "env": {
        "FIRECRAWL_API_KEY": "YOUR_FIRECRAWL_API_KEY"
      }
    },

    "_comment_optional_automation": "=== OPCIONALES: Automatización ===",

    "n8n-mcp": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e", "MCP_MODE=stdio",
        "-e", "LOG_LEVEL=error",
        "-e", "DISABLE_CONSOLE_OUTPUT=true",
        "-e", "N8N_API_URL=YOUR_N8N_API_URL",
        "-e", "N8N_API_KEY=YOUR_N8N_API_KEY",
        "ghcr.io/czlonkowski/n8n-mcp:latest"
      ]
    }

  }
}
